{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "incremental": false,
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "dist-worker",
    "rootDir": "src",
    "sourceMap": false,
    "types": ["node"]
  },
  "include": [
    "src/worker/**/*.ts",
    "src/config/**/*.ts",
    "src/server/db/**/*.ts",
    "src/generated/prisma/**/*.ts"
  ],
  "exclude": ["**/*.test.ts", "**/*.integration.test.ts"]
}
